{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "biji2md",
  "version": "1.0.0",
  "identifier": "com.duoshilin.biji2md",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run frontend:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "biji2md",
        "width": 1120,
        "height": 760,
        "minWidth": 920,
        "minHeight": 680,
        "resizable": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVCQTE2MUVDMEEwM0Q5RTUKUldUbDJRTUs3R0doVzd3dllESmlFc1M1SjY5ZnU2SXpncGV4WFI2NHd0MXZqMnMyTTNTTUpNc0gK",
      "endpoints": [
        "https://github.com/Duosl/biji2md_tauri/releases/latest/download/latest.json",
        "https://kkgithub.com/https://github.com/Duosl/biji2md_tauri/releases/latest/download/latest.json"
      ]
    }
  }
}
