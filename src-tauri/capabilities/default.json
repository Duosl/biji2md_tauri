{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window capability set",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "process:allow-restart",
    "shell:default",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
